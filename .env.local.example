# Copy this file to .env.local and fill in your Convex credentials.
# `npx convex dev` writes NEXT_PUBLIC_CONVEX_URL + CONVEX_DEPLOYMENT
# automatically the first time you run it.

NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=dev:your-project-name

# Server-only secret used to derive a per-phone password for Convex Auth's
# Password provider. Generate with:  openssl rand -hex 32
PHONE_AUTH_SECRET=replace-with-a-long-random-hex-string
